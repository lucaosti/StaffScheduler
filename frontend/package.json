{
  "name": "staff-scheduler-frontend",
  "version": "1.0.0",
  "description": "Frontend React application for Staff Scheduler - Advanced Workforce Management System",
  "private": true,
  "dependencies": {
    "@tanstack/react-query": "^5.101.4",
    "bootstrap": "^5.3.0",
    "bootstrap-icons": "^1.10.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^29.5.3",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^29.6.1",
    "jest-environment-jsdom": "^30.4.1",
    "knip": "^6.7.0",
    "msw": "^2.7.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.4",
    "sass": "^1.64.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.4.0",
    "vite": "^6.0.0"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "deadcode": "knip",
    "format": "prettier --write src/**/*.{ts,tsx,css,scss}",
    "analyze": "npm run build && npx source-map-explorer 'build/assets/*.js'",
    "api:generate": "openapi-typescript ../backend/openapi/openapi.json -o src/api/schema.ts"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
