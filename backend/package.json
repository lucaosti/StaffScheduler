{
  "name": "staff-scheduler-backend",
  "version": "1.0.0",
  "description": "Backend API for Staff Scheduler - Advanced Workforce Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testMatch='**/*.integration.test.ts' --testPathIgnorePatterns='/node_modules/' --runInBand --coverage=false",
    "test:optimization": "jest --testMatch='**/*optimization*.test.ts'",
    "test:performance": "jest --testMatch='**/*performance*.test.ts' --verbose",
    "deadcode:cycles": "madge --circular --extensions ts src",
    "deadcode:tests": "ts-node scripts/find-test-only-exports.ts",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src/**/*.ts",
    "db:init": "npx ts-node scripts/db-migrate.ts up",
    "db:seed:demo": "npx ts-node scripts/seed-demo.ts",
    "db:seed:production": "npx ts-node scripts/seed-production.ts",
    "sim:run": "npx ts-node scripts/simulation/index.ts",
    "sim:campaign": "npx ts-node scripts/simulation/campaign.ts",
    "deadcode": "knip",
    "clean": "rm -rf dist",
    "db:migrate": "npx ts-node scripts/db-migrate.ts up",
    "db:migrate:status": "npx ts-node scripts/db-migrate.ts status",
    "db:migrate:rollback": "npx ts-node scripts/db-migrate.ts rollback",
    "db:migrate:new": "npx ts-node scripts/db-migrate.ts new",
    "openapi:generate": "npx ts-node scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.221.0",
    "@opentelemetry/resources": "^2.10.0",
    "@opentelemetry/sdk-node": "^0.221.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@staff-scheduler/shared": "1.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.80.10",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.22.5",
    "nodemailer": "^9.0.3",
    "prom-client": "^15.1.3",
    "swagger-ui-dist": "^5.32.11",
    "winston": "^3.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.4.5",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^2.0.12",
    "@types/swagger-ui-dist": "^3.30.6",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.61.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "dbmate": "^2.34.1",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "jest": "^29.6.1",
    "knip": "^6.7.0",
    "madge": "^8.0.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.8.4",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
