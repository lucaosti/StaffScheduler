# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=staff_scheduler
DB_USER=scheduler_user
DB_PASSWORD=scheduler_password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
# Refresh-token lifetime (the session length). Rotated on every use.
JWT_REFRESH_EXPIRES_IN=30d

# Redis Configuration
# On by default: the shared caches (token-revocation blacklist, auth-context,
# module state) use Redis whenever it is reachable, so multiple backend
# instances stay consistent and token revocation survives a restart. If no
# Redis is running the caches fall back to in-process state automatically.
# Point REDIS_URL at your instance (include the password: redis://:pass@host:6379);
# set REDIS_ENABLED=false to disable Redis entirely for a single-instance deployment.
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=true

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM_NAME=Staff Scheduler
EMAIL_FROM_ADDRESS=noreply@staffscheduler.com

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# Report Configuration
REPORT_STORAGE_PATH=./reports
REPORT_CLEANUP_DAYS=30

# Optimization engine. 'or-tools' (default) = optimal Python CP-SAT solver, with
# a signalled greedy fallback if Python is unavailable. 'greedy' (or legacy
# 'javascript') = fast best-effort draft engine, chosen on purpose.
OPTIMIZATION_ENGINE=or-tools
OPTIMIZATION_TIMEOUT=300000
OPTIMIZATION_MAX_ITERATIONS=10000
OPTIMIZATION_POPULATION_SIZE=100
OPTIMIZATION_MUTATION_RATE=0.1
OPTIMIZATION_CROSSOVER_RATE=0.8

# Observability. Bearer token protecting GET /metrics (Prometheus scrape).
# Leave empty for local dev; set it in any networked deployment so metrics are
# not exposed unauthenticated.
METRICS_TOKEN=

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Auth-context cache TTL in milliseconds. 0 (default) = disabled: permissions
# are re-resolved from the database on every request so grants/revocations
# apply immediately. A small TTL (e.g. 5000) cuts the ~6 auth queries per
# request at the cost of revocations taking up to TTL to propagate.
AUTH_PERMISSION_CACHE_TTL_MS=0

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Notifications Configuration
NOTIFICATIONS_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=true
IN_APP_NOTIFICATIONS_ENABLED=true
